# Node
node_modules/
npm-debug.log*
.env

# Flutter / Dart build artifacts
app/build/
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
*.log

# Android signing secrets (also covered by app/android/.gitignore)
